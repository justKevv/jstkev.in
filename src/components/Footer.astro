---
const currentPath = Astro.url.pathname;
const footItems = [
  { href: "https://github.com/justKevv", label: "Github" },
  { href: "https://www.linkedin.com/in/kevin-bramasta/", label: "Linkedin" },
  { href: "mailto:kevinbramastaa@gmail.com", label: "Email" },
  { href: "/kevin_bramasta_softwaredeveloper.pdf", label: "Resume" },
];
const showFooter = ["/", "/blogs"].includes(currentPath);
---

{showFooter ?
  <footer class="flex text-[12px] lg:text-[13px] justify-between px-10 py-8">
      <section class="flex flex-col items-start gap-2.5">
          {footItems.map((item) => (
            <a class="footer-line relative inline-block after:content-[''] after:absolute after:left-0 after:bottom-0 after:h-px after:w-full after:bg-current after:origin-left after:scale-x-0 after:transition-transform after:duration-250 hover:after:scale-x-100" href={item.href} target="_blank">{item.label}</a>
          ))}
          {currentPath === "/" ? <span class="footer-line text-black/50">Model by <a class="underline" href="https://sketchfab.com/ChrisSweetwood" target="_blank">Chris Sweetwood</a></span> : ""}
      </section>
      {currentPath === "/" ?
        <a class="latest border py-3 px-5 rounded-full whitespace-nowrap self-end-safe" href="/projects/sentry">Latest Project</a>
        : ""
      }
  </footer>
  : ""
}
