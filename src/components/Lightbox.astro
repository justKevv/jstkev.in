<div id="lightbox" class="fixed inset-0 z-50 hidden items-center justify-center bg-ink/80 backdrop-blur-sm p-4">
  <div id="lightbox-inner" class="flex flex-col items-center gap-4">
    <img id="lightbox-img" src="" alt="" class="w-full max-w-3xl max-h-[85vh] object-contain rounded-sm cursor-zoom-out" />
    <p id="lightbox-caption" class="font-mono text-[15px] tracking-[0.15em] capitalize text-bg/90"></p>
  </div>
</div>

<script>
  import { gsap } from "gsap";

  let clickHandler: ((e: MouseEvent) => void) | null = null;
  let keyHandler: ((e: KeyboardEvent) => void) | null = null;

  document.addEventListener('astro:page-load', () => {
    const lightbox = document.getElementById('lightbox');
    const lightboxInner = document.getElementById('lightbox-inner');
    const lightboxImg = document.getElementById('lightbox-img') as HTMLImageElement;
    const lightboxCaption = document.getElementById('lightbox-caption');

    if (!lightbox) return;

    function openLightbox() {
      gsap.set(lightbox, { opacity: 0 });
      gsap.set(lightboxInner, { opacity: 0, scale: 0.95, y: 10 });
      lightbox!.classList.remove('hidden');
      lightbox!.classList.add('flex');
      document.body.style.overflow = 'hidden';
      gsap.to(lightbox, { opacity: 1, duration: 0.3, ease: "expo.out" });
      gsap.to(lightboxInner, { opacity: 1, scale: 1, y: 0, duration: 0.4, ease: "expo.out" });
    }

    function closeLightbox() {
      gsap.to(lightboxInner, { opacity: 0, scale: 0.95, y: 10, duration: 0.2, ease: "expo.in" });
      gsap.to(lightbox, {
        opacity: 0, duration: 0.25, ease: "expo.in",
        onComplete: () => {
          lightbox!.classList.add('hidden');
          lightbox!.classList.remove('flex');
          document.body.style.overflow = '';
          gsap.set(lightbox, { opacity: 1 });
          gsap.set(lightboxInner, { opacity: 1, scale: 1, y: 0 });
        }
      });
    }

    if (clickHandler) document.removeEventListener('click', clickHandler);
    if (keyHandler) document.removeEventListener('keydown', keyHandler);

    clickHandler = (e) => {
      if (!lightbox!.classList.contains('hidden')) {
        closeLightbox();
        return;
      }

      const target = (e.target as HTMLElement).closest('[data-lightbox]') as HTMLElement;
      if (target) {
        lightboxImg!.src = target.dataset.src ?? '';
        lightboxImg!.alt = target.dataset.caption ?? '';
        lightboxCaption!.textContent = target.dataset.caption ?? '';
        openLightbox();
      }
    };

    keyHandler = (e) => { if (e.key === 'Escape') closeLightbox(); };

    document.addEventListener('click', clickHandler);
    document.addEventListener('keydown', keyHandler);
  });
</script>
