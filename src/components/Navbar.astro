---
const navItems = [
  { href: "/blogs", label: "blogs" },
  { href: "/certificates", label: "certs" },
  { href: "/projects", label: "projects" },
  { href: "/works", label: "works" },
];
---

<header class="w-full h-fit relative z-60 transform-gpu will-change-transform">
    <nav class="flex justify-between items-center py-6 px-10">
        <a href="/" class="nav-split text-lg lg:text-xl">文</a>
        <div class="flex items-center gap-4">
            {navItems.map((item, i) => (
              <>
                <a class="nav-split relative inline-block after:content-[''] after:absolute after:left-0 after:bottom-0 after:h-px after:w-full after:bg-current after:origin-left after:scale-x-0 after:transition-transform after:duration-250 hover:after:scale-x-100 text-[13.5px] lg:text-[14px]" href={item.href}>{item.label}</a>
                {i < navItems.length - 1 && (
                  <span class="nav-split w-1 h-1 rounded-full bg-black" />
                )}
              </>
            ))}
        </div>
    </nav>
</header>
