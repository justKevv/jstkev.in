---
import type { ProjectItem } from "../../types/project";
const props = Astro.props as ProjectItem;
import { Image } from "astro:assets";
---

<article class="project-card h-full">
    <a href={`/projects/${props.content_link}`} class="flex h-full min-h-72 flex-col gap-3 rounded-xl border border-black/60 p-5 transition hover:shadow-sm focus:outline-none focus-visible:ring-2 focus-visible:ring-black/40">
        {props.image ? <Image class="h-40 w-full object-cover rounded-lg bg-black/60" src={props.image} alt={props.name}/>
          : <div class="h-40 w-full rounded-lg bg-black/60" aria-hidden="true"></div>
        }

        <h3 class="text-base capitalize font-medium">{props.name}</h3>
        <p class="text-sm text-zinc-700">{props.description}</p>

        <ul class="flex flex-wrap gap-2" aria-label="Tech stack">
            {props.stack.map((tech) => (
              <li class="inline-flex select-none items-center rounded-full border px-3 py-1 border-black/60 text-black/60 text-sm">{tech}</li>
            ))}
        </ul>
    </a>
</article>
