---
import { stackUrls } from "../../data/stacksUrls";
import type { WorkItem } from "../../types/work";
const props = Astro.props as WorkItem & { index: number };
---

<details class="group work-split">
  <summary class="list-none [&::-webkit-details-marker]:hidden cursor-pointer py-3">
    <div class="grid gap-3 sm:flex sm:items-start sm:gap-6">
      <div class="flex items-center justify-between sm:w-10 sm:block">
        <p class="m-0 text-sm text-black/60 sm:text-base">{String(props.index).padStart(2, "0")}</p>

        <div class="flex items-center gap-3 sm:hidden">
          <p class="m-0 text-xs text-black/60 capitalize">{props.date}</p>
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="shrink-0 transition-transform duration-200 group-open:rotate-180">
            <path d="m6 9 6 6 6-6" />
          </svg>
        </div>
      </div>

      <div class="min-w-0 flex-1 grid gap-2">
        <h2 class="m-0 text-base font-family-playfair leading-snug capitalize sm:text-lg">{props.role}</h2>

        <div class="flex flex-wrap gap-2 capitalize text-[11px] sm:text-xs text-black/70">
          <p class="m-0 border rounded-full py-1 px-3">{props.company}</p>
          <p class="m-0 border rounded-full py-1 px-3">{props.type}</p>
          <p class="m-0 border rounded-full py-1 px-3">{props.location}</p>
        </div>
      </div>

      <p class="m-0 hidden sm:block shrink-0 text-right text-black/60 capitalize">{props.date}</p>
      <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="hidden sm:block shrink-0 transition-transform duration-200 group-open:rotate-180">
        <path d="m6 9 6 6 6-6" />
      </svg>
    </div>
  </summary>

  <div class="pb-5 pt-1 text-sm text-black/80 sm:pl-16 sm:pr-8">
    {props.highlights?.length ? (
      <ul class="m-0 mb-4 pl-5 space-y-1">
        {props.highlights.map((item) => <li class="list-disc">{item}</li>)}
      </ul>
    ) : null}

    {props.stack?.length ? (
      <div class="flex flex-wrap gap-2">
        {props.stack.map((tech) => (
          <a href={stackUrls[tech]} target="_blank" class="border hover:bg-neutral-100 transition duration-200 rounded-full py-1 px-3 text-xs">
            {tech}
          </a>
        ))}
      </div>
    ) : null}
  </div>
</details>
