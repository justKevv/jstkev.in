---
import type { WorkItem } from "../../types/work";
const props = Astro.props as WorkItem;
---

<div class="work-item py-6 cursor-pointer group not-last:border-b border-ink/10" onclick="this.classList.toggle('open')">
    <div class="flex items-start gap-4">
        <!-- arrow always top right -->
        <svg class="toggle-icon text-ink/60 transition-transform duration-300 w-2 h-2 shrink-0 mt-1.5" viewBox="0 0 6 6" fill="currentColor">
            <polygon points="0,0 6,3 0,6"/>
        </svg>
        
        <!-- everything on the left -->
        <div class="flex flex-col gap-0.5 min-w-0">
            <span class="text-[14px] text-ink/60 tracking-[0.15em] uppercase font-mono">{props.company}</span>
            <span class="text-2xl text-ink/80 tracking-tight capitalize font-serif group-hover:text-ink transition-opacity duration-250">{props.role}</span>
            <span class="text-[14px] border-2 border-[#EDE8E0] w-fit px-2 py-0.5 text-ink/65 font-mono">{props.type}</span>
            <div class="text-[14px] flex flex-wrap gap-x-2 mt-1.5">
                <span class="text-ink/55 font-mono">{props.location}</span>
                <span class="text-ink/40 font-mono">·</span>
                <span class="text-ink/55 font-mono">{props.date}</span>
            </div>
            <div class="flex flex-wrap gap-x-1 mt-1">
                {props.stack.map((s: string, i: number) => (
                    <span class="text-[14px] text-accent/60 font-mono">{s}{i < props.stack.length - 1 ? ' ·' : ''}</span>
                ))}
            </div>
        </div>

    </div>

    <div class="work-details grid transition-all duration-300 ease-in-out">
        <div class="overflow-hidden">
            <ul class="list-disc ml-5 mt-4 space-y-1 pb-1">
                {props.highlights.map((point: string) => (
                    <li class="font-serif text-md text-ink/55 leading-relaxed">
                        {point}
                    </li>
                ))}
            </ul>
        </div>
    </div>
</div>

<style>
    .work-details {
        grid-template-rows: 0fr;
    }
    .work-item.open .work-details {
        grid-template-rows: 1fr;
    }
    .work-item.open .toggle-icon {
        transform: rotate(90deg);
    }
</style>
