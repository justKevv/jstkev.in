---
const { subject, character, pinyin, translation } = Astro.props;
---
<div class="flex flex-col gap-2">
    <span class="font-mono text-[13px] tracking-[0.2em] text-ink/30 uppercase">subject.{subject}</span>
  <h1 class="font-serif text-4xl sm:text-5xl text-ink tracking-tight leading-none">【{character}】</h1>
  <p class="font-mono text-lg text-ink/40">{pinyin} · <span class="font-bold text-ink/80">{translation}</span></p>
  <slot/>
</div>