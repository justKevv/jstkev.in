---
const { current } = Astro.props
---

<div class="flex flex-col gap-4 font-mono text-[12px] tracking-widest text-ink/40 uppercase mt-8 mb-12">
    <div class="flex items-center gap-2">
        <a href="/" class="hover:text-ink transition-colors duration-200">jst.kevv</a>
        <span>/</span>
        <span class="text-ink">{current}</span>
    </div>
    <a href="/" class="flex items-center gap-2 hover:text-ink transition-all duration-200 group w-fit">
        <svg class="w-3 h-3 rotate-180 transition-transform duration-200 group-hover:-translate-x-0.5" viewBox="0 0 10 10" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <line x1="1" y1="9" x2="9" y2="1"/>
            <polyline points="3,1 9,1 9,7"/>
