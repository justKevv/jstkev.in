<!-- GenkoBackground.astro -->
<canvas id="genko-bg"></canvas>

<style>
    #genko-bg {
        position: fixed;
        inset: 0;
        width: 100%;
        height: 100%;
        z-index: 0;
        pointer-events: none;
        background-color: #F7F3EE;
    }
</style>

<script is:inline>
    const canvas = document.getElementById("genko-bg");
    const ctx = canvas.getContext("2d");

    let W, H, time = 0;
    const CELL = 44;
    const GAP = 8;
    const colStep = CELL + GAP;

    function getZoneWidth() {
        const layout = document.querySelector(".content-layout");
        return layout ? layout.getBoundingClientRect().width : Math.min(W * 0.85, 680);
    }

    function resize() {
        W = canvas.width = window.innerWidth;
        H = canvas.height = window.innerHeight;
    }

    function draw() {
        ctx.clearRect(0, 0, W, H);
        time += 0.004;

        const baseAlpha = 0.11 + Math.sin(time) * 0.02;
        const rows = Math.ceil(H / CELL) + 1;

        const offset = (W / 2) % colStep - CELL / 2;
        const cols = Math.ceil(W / colStep) + 2;

        // read directly from the DOM element
        const zoneWidth = getZoneWidth();
        const centerX1 = (W / 2) - (zoneWidth / 2);
        const centerX2 = (W / 2) + (zoneWidth / 2);

        ctx.lineWidth = 0.5;

        for (let r = 0; r < rows; r++) {
            for (let c = -1; c < cols; c++) {
                const x = offset + c * colStep - colStep;
                const y = r * CELL;

                if (x + CELL > centerX1 && x < centerX2) continue;

                ctx.strokeStyle = `rgba(20, 20, 20, ${baseAlpha})`;
                ctx.beginPath();
                ctx.rect(x, y, CELL, CELL);
                ctx.stroke();

                const inset = CELL * 0.15;
                ctx.strokeStyle = `rgba(20, 20, 20, ${baseAlpha * 0.4})`;
                ctx.beginPath();
                ctx.rect(x + inset, y + inset, CELL - inset * 2, CELL - inset * 2);
                ctx.stroke();
            }
        }

        requestAnimationFrame(draw);
    }

    resize();
    window.addEventListener("resize", resize);
    draw();
</script>

