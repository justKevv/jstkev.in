<canvas id="genko-bg" transition:persist></canvas>
<div id="genko-overlays" transition:persist style="position:fixed;inset:0;pointer-events:none;z-index:10;"></div>

<style is:global>
    #genko-bg {
        position: fixed;
        inset: 0;
        width: 100%;
        height: 100%;
        z-index: 0;
        pointer-events: none;
        background-color: var(--color-bg);
    }

    .genko-btn {
        position: absolute;
        display: block;
        pointer-events: auto !important;
        cursor: pointer;
        z-index: 10;
    }

    .genko-btn .bracket {
        position: absolute;
        width: 12px;
        height: 12px;
        opacity: 0;
        transform: scale(1.6);
        transition: opacity 0.35s ease, transform 0.35s ease;
    }

    .genko-btn .bracket-tl { top: 0; left: 0; border-top: 2px solid rgba(var(--color-ink-rgb), 1); border-left: 2px solid rgba(var(--color-ink-rgb), 1); }
    .genko-btn .bracket-tr { top: 0; right: 0; border-top: 2px solid rgba(var(--color-ink-rgb), 1); border-right: 2px solid rgba(var(--color-ink-rgb), 1); }
    .genko-btn .bracket-bl { bottom: 0; left: 0; border-bottom: 2px solid rgba(var(--color-ink-rgb), 1); border-left: 2px solid rgba(var(--color-ink-rgb), 1); }
    .genko-btn .bracket-br { bottom: 0; right: 0; border-bottom: 2px solid rgba(var(--color-ink-rgb), 1); border-right: 2px solid rgba(var(--color-ink-rgb), 1); }

    .genko-btn:hover .bracket {
        opacity: 0.5;
        transform: scale(1);
    }
</style>


<script is:inline>
    if (!window.__genkoInit) {
        window.__genkoInit = true;

        const groups = ["电影", "凯文", "你好"];
        const hrefs = ["/films", "/kevin", "/hello"];

        let placedChars = [];
        let W, H;
        let time = 0;
        const CELL = 55;
        const GAP = 12;
        const colStep = CELL;
        const rowStep = CELL + GAP;
        let zone = { cx1: 0, cx2: 0 };

        const canvas = document.getElementById("genko-bg");
        const ctx = canvas.getContext("2d");

        function getInkRgb() {
            return getComputedStyle(document.documentElement).getPropertyValue('--color-ink-rgb').trim() || '26, 26, 26';
        }

        function shuffle(arr) {
            for (let i = arr.length - 1; i > 0; i--) {
                const j = Math.floor(Math.random() * (i + 1));
                [arr[i], arr[j]] = [arr[j], arr[i]];
            }
            return arr;
        }

        function getZone() {
            const layout = document.querySelector(".content-layout");
            const rect = layout
                ? layout.getBoundingClientRect()
                : { left: W / 2 - Math.min(W * 0.85, 700) / 2, right: W / 2 + Math.min(W * 0.85, 700) / 2 };
            return { cx1: rect.left, cx2: rect.right };
        }

        function placeCharacters() {
            placedChars = [];
            const { cx1, cx2 } = zone;
            const offsetL = cx1 - Math.ceil(cx1 / colStep) * colStep;
            const offsetR = cx2 - Math.floor(cx2 / colStep) * colStep;
            const totalCols = Math.ceil(W / colStep) + 2;
            const NEAR_COLS = 3;
            const rowMin = Math.floor((H * 0.3) / rowStep);
            const rowMax = Math.ceil((H * 0.7) / rowStep);
            const validCols = new Set();
            const available = [];

            for (let col = -1; col < totalCols; col++) {
                // Try left band first
                const xL = offsetL + col * colStep;
                if (xL + CELL <= cx1) {
                    const distToZone = cx1 - (xL + CELL);
                    if (distToZone <= NEAR_COLS * colStep) {
                        validCols.add(`L:${col}`);
                        for (let row = rowMin; row < rowMax; row++) available.push({ col, row, band: 'L' });
                    }
                }
                // Right band
                const xR = offsetR + col * colStep;
                if (xR >= cx2) {
                    const distToZone = xR - cx2;
                    if (distToZone <= NEAR_COLS * colStep) {
                        validCols.add(`R:${col}`);
                        for (let row = rowMin; row < rowMax; row++) available.push({ col, row, band: 'R' });
                    }
                }
            }

            shuffle(available);
            const occupied = new Set();
            const key = (band, col, row) => `${band}:${col},${row}`;

            for (let gi = 0; gi < groups.length; gi++) {
                const chars = [...groups[gi]];
                let placed = false;
                for (const cell of available) {
                    const allColsValid = chars.every((_, ci) => validCols.has(`${cell.band}:${cell.col + ci}`));
                    if (!allColsValid) continue;
                    const fits = chars.every((_, ci) => !occupied.has(key(cell.band, cell.col + ci, cell.row)));
                    if (!fits) continue;
                    chars.forEach((ch, ci) => {
                        const col = cell.col + ci;
                        occupied.add(key(cell.band, col, cell.row));
                        const offset = cell.band === 'L' ? offsetL : offsetR;
                        placedChars.push({ char: ch, gridCol: col, gridRow: cell.row, groupIdx: gi, offset });
                    });
                    placed = true;
                    break;
                }
                if (!placed) console.warn(`Could not place group: "${groups[gi]}"`);
            }
        }

        function updateOverlays() {
            const container = document.getElementById("genko-overlays");
            if (!container) return;
            container.innerHTML = "";
            const offset = zone.cx1 - Math.ceil(zone.cx1 / colStep) * colStep;
            const byGroup = {};
            placedChars.forEach((c) => {
                if (!byGroup[c.groupIdx]) byGroup[c.groupIdx] = [];
                byGroup[c.groupIdx].push(c);
            });
            Object.entries(byGroup).forEach(([gi, chars]) => {
                const minCol = Math.min(...chars.map((c) => c.gridCol));
                const maxCol = Math.max(...chars.map((c) => c.gridCol));
                const row = chars[0].gridRow;
                const x = chars[0].offset + minCol * colStep;
                const y = chars[0].gridRow * rowStep;
                const w = (maxCol - minCol + 1) * colStep;
                const a = document.createElement("a");
                a.href = hrefs[gi] ?? "/";
                a.className = "genko-btn";
                a.setAttribute("aria-label", groups[gi]);
                a.style.left   = `${x}px`;
                a.style.top    = `${y}px`;
                a.style.width  = `${w}px`;
                a.style.height = `${CELL}px`;
                a.innerHTML = `
                    <span class="bracket bracket-tl"></span>
                    <span class="bracket bracket-tr"></span>
                    <span class="bracket bracket-bl"></span>
                    <span class="bracket bracket-br"></span>
                `;
                container.appendChild(a);
            });
        }

        function resize() {
            // Full resize: recalculate dimensions, re-place chars, update overlays.
            // Only called on true window resize events.
            W = canvas.width = window.innerWidth;
            H = canvas.height = window.innerHeight;
            zone = getZone();
            placeCharacters();
            updateOverlays();
        }

        function refreshOffsets() {
            const { cx1, cx2 } = zone;
            const offsetL = cx1 - Math.ceil(cx1 / colStep) * colStep;
            const offsetR = cx2 - Math.floor(cx2 / colStep) * colStep;
            placedChars.forEach((c) => {
                // Determine band by which side of cx1 the char was on
                const xL = offsetL + c.gridCol * colStep;
                c.offset = xL + CELL <= cx1 ? offsetL : offsetR;
            });
        }

        function refreshOverlays() {
            W = canvas.width = window.innerWidth;
            H = canvas.height = window.innerHeight;
            zone = getZone();
            refreshOffsets();
            updateOverlays();
        }

        function drawCell(x, y, ink, baseAlpha) {
            ctx.strokeStyle = `rgba(${ink}, ${baseAlpha})`;
            ctx.beginPath();
            ctx.rect(x, y, CELL, CELL);
            ctx.stroke();
            const inset = CELL * 0.15;
            ctx.strokeStyle = `rgba(${ink}, ${baseAlpha * 0.4})`;
            ctx.beginPath();
            ctx.rect(x + inset, y + inset, CELL - inset * 2, CELL - inset * 2);
            ctx.stroke();
        }

        function draw() {
          ctx.clearRect(0, 0, W, H);
          time += 0.004;
          const ink = getInkRgb();
          const baseAlpha = 0.2 + Math.sin(time) * 0.02;
          const rows = Math.ceil(H / rowStep) + 1;
          const { cx1, cx2 } = zone;

          // Left band: anchor grid to cx1 (cells end flush at cx1)
          const offsetL = cx1 - Math.ceil(cx1 / colStep) * colStep;
          // Right band: anchor grid to cx2 (cells start flush at cx2)
          const offsetR = cx2 - Math.floor(cx2 / colStep) * colStep;

          ctx.lineWidth = 0.5;
          for (let r = 0; r < rows; r++) {
              const y = r * rowStep;

              // Left columns
              for (let c = -1; c * colStep + offsetL < cx1; c++) {
                  const x = offsetL + c * colStep;
                  if (x + CELL > cx1) continue;
                  drawCell(x, y, ink, baseAlpha);
              }

              // Right columns
              for (let c = 0; offsetR + c * colStep < W; c++) {
                  const x = offsetR + c * colStep;
                  if (x < cx2) continue;
                  drawCell(x, y, ink, baseAlpha);
              }
          }
          placedChars.forEach((c) => {
              const charX = c.offset + c.gridCol * colStep + CELL / 2;
              const charY = c.gridRow * rowStep + CELL / 2;
              ctx.font = `${CELL * 0.55}px Mori, serif`;
              ctx.fillStyle = `rgba(${ink}, 0.27)`;
              ctx.textAlign = "center";
              ctx.textBaseline = "middle";
              ctx.fillText(c.char, charX, charY);
          });
          requestAnimationFrame(draw);
        }

        window.__genkoRefresh = refreshOverlays;

        resize();
        window.addEventListener("resize", resize);
        document.fonts.load("500 55px Mori").then(() => { draw(); });

        document.addEventListener("astro:after-swap", () => {
            window.__genkoRefresh();
        });
    } else {
        window.__genkoRefresh && window.__genkoRefresh();
    }
</script>
