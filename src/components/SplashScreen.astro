<div id="splash">
    <h1 id="split" style="opacity: 0;">文</h1>
</div>

<style>
    #split {
        font-family: Mori, sans-serif;
        font-size: 3.4rem;
        font-weight: 500;
        color: black;
        will-change: transform;
        transform: translateZ(0);
        -webkit-touch-callout: none;
        -webkit-user-select: none;
        -khtml-user-select: none;
        -moz-user-select: none;
        -ms-user-select: none;
        user-select: none;
    }

    #splash {
        position: fixed;
        inset: 0;
        background-color: #F9FAFB;
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 999;
        opacity: 1;
    }
</style>

<script>
    import { gsap } from "gsap";
    import { SplitText } from "gsap/SplitText";

    gsap.registerPlugin(SplitText);

    document.body.style.overflow = "hidden";

    function runSplash() {
        const splitEl = document.getElementById("split");
        const heroEl = document.getElementById("hero-wen");
        
        // wait for both elements to exist
        if (!splitEl || !heroEl) {
            requestAnimationFrame(runSplash);
            return;
        }

        gsap.set(splitEl, { opacity: 1 });

        let hasRun = false;

        SplitText.create(splitEl, {
            type: "words,lines",
            linesClass: "line",
            autoSplit: false,
            mask: "lines",
            onSplit(self) {
                if (hasRun) return;
                hasRun = true;

                const tl = gsap.timeline({
                    onComplete() {
                        const clone = document.createElement("span");
                        clone.textContent = "文";

                        const vCx = window.innerWidth / 2;
                        const vCy = window.innerHeight / 2;

                        clone.style.cssText = `
                            position: fixed;
                            font-family: Mori, sans-serif;
                            font-size: 3.4rem;
                            font-weight: 500;
                            color: black;
                            z-index: 1000;
                            pointer-events: none;
                            top: 0;
                            left: 0;
                            transform-origin: center center;
                            will-change: transform;
                        `;
                        document.body.appendChild(clone);
                        gsap.set(splitEl, { opacity: 0 });

                        const cloneRect = clone.getBoundingClientRect();
                        const startX = vCx - cloneRect.width / 2;
                        const startY = vCy - cloneRect.height / 2;
                        gsap.set(clone, { x: startX, y: startY });

                        // force layout before measuring hero
                        heroEl.style.visibility = "hidden";
                        heroEl.style.opacity = "1";
                        const heroRect = heroEl.getBoundingClientRect();
                        heroEl.style.opacity = "0";
                        heroEl.style.visibility = "";

                        const endX = heroRect.left;
                        const endY = heroRect.top;

                        const fromSize = parseFloat(getComputedStyle(clone).fontSize);
                        const toSize = parseFloat(getComputedStyle(heroEl).fontSize);
                        const scale = toSize / fromSize;

                        const exitTl = gsap.timeline({
                            onComplete() {
                                clone.remove();
                                const splash = document.getElementById("splash");
                                if (splash) splash.style.display = "none";
                                gsap.set(heroEl, { opacity: 1 });
                                document.body.style.overflow = "";
                            },
                        });

                        exitTl.to(clone, {
                            x: endX,
                            y: endY,
                            scale,
                            transformOrigin: "top left",
                            color: "#EA580C",
                            opacity: 0.6,
                            duration: 0.9,
                            ease: "expo.inOut",
                        });

                        exitTl.to("#splash", {
                            opacity: 0,
                            duration: 0.35,
                            ease: "power2.in",
                        }, "-=0.3");
                    },
                });

                tl.from(self.lines, {
                    duration: 0.6,
                    yPercent: 100,
                    opacity: 0,
                    stagger: 0.1,
                    ease: "expo.out",
                    delay: 0.3,
                });

                tl.to(self.lines, { duration: 0.85 });
            },
        });
    }

    // wait for fonts AND full DOM
    document.fonts.ready.then(() => {
        requestAnimationFrame(() => requestAnimationFrame(runSplash));
    });
</script>


