<!-- SplashScreen.astro -->
<div id="splash">
    <h1 id="split" style="opacity: 0;">文</h1>
</div>

<style>
    #split {
        font-family: Mori, sans-serif;
        font-size: 3.4rem;
        font-weight: 500;
        color: black;
        will-change: transform;
        transform: translateZ(0);
        -webkit-touch-callout: none;
        -webkit-user-select: none;
        -khtml-user-select: none;
        -moz-user-select: none;
        -ms-user-select: none;
        user-select: none;
    }

    #splash {
        position: fixed;
        inset: 0;
        background-color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 999;
        opacity: 1;
    }
</style>

<script>
    import { gsap } from "gsap";
    import { SplitText } from "gsap/SplitText";

    gsap.registerPlugin(SplitText);

    document.body.style.overflow = "hidden";

    function runSplash() {
        const splitEl = document.getElementById("split");
        if (!splitEl) return;

        gsap.set(splitEl, { opacity: 1 });

        let hasRun = false;

        SplitText.create(splitEl, {
            type: "words,lines",
            linesClass: "line",
            autoSplit: false,
            mask: "lines",
            onSplit(self) {
                if (hasRun) return;
                hasRun = true;

                const tl = gsap.timeline({
                    onComplete() {
                        const clone = document.createElement("span");
                        clone.textContent = "文";
                        clone.style.cssText = `
                            position: fixed;
                            font-family: Mori, sans-serif;
                            font-size: 3.4rem;
                            font-weight: 500;
                            color: black;
                            z-index: 1000;
                            pointer-events: none;
                            top: 50%;
                            left: 50%;
                            transform: translate(-50%, -50%);
                        `;
                        document.body.appendChild(clone);
                        gsap.set(splitEl, { opacity: 0 });

                        const cloneRect = clone.getBoundingClientRect();

                        const heroEl = document.getElementById("hero-wen");
                        if (!heroEl) return;
                        heroEl.style.visibility = "hidden";
                        heroEl.style.opacity = "1";
                        const heroRect = heroEl.getBoundingClientRect();
                        heroEl.style.opacity = "0";
                        heroEl.style.visibility = "";

                        const fromCx = cloneRect.left + cloneRect.width  / 2;
                        const fromCy = cloneRect.top  + cloneRect.height / 2;
                        const toCx   = heroRect.left  + heroRect.width   / 2;
                        const toCy   = heroRect.top   + heroRect.height  / 2;
                        const scale  = heroRect.height / cloneRect.height;

                        const exitTl = gsap.timeline({
                            onComplete() {
                                clone.remove();
                                const splash = document.getElementById("splash");
                                if (splash) splash.style.display = "none";
                                gsap.set(heroEl, { opacity: 1 });
                                document.body.style.overflow = "";
                            },
                        });

                        exitTl.to(clone, {
                            x: toCx - fromCx,
                            y: toCy - fromCy,
                            scale,
                            color: "#EA580C",
                            opacity: 0.6,
                            duration: 0.9,
                            ease: "expo.inOut",
                        });

                        exitTl.to("#splash", {
                            opacity: 0,
                            duration: 0.35,
                            ease: "power2.in",
                        }, "-=0.3");
                    },
                });

                tl.from(self.lines, {
                    duration: 0.6,
                    yPercent: 100,
                    opacity: 0,
                    stagger: 0.1,
                    ease: "expo.out",
                    delay: 0.3,
                });

                tl.to(self.lines, { duration: 0.4 });
            },
        });
    }

    requestAnimationFrame(() => requestAnimationFrame(runSplash));
</script>


