---
import BreadCrumbs from "../components/BreadCrumbs.astro";
import ContentLayout from "../layouts/ContentLayout.astro";
import DetectionCard from "../layouts/DetectionCard.astro";
import MainLayout from "../layouts/MainLayout.astro";
import ChineseCard from "../components/cards/ChineseCard.astro";

import { topFilms } from '../data/films';

const LETTERBOXD_USER = 'justakevv';
---

<MainLayout>
    <ContentLayout>
        <BreadCrumbs current="films"/>
        <DetectionCard subject="films">
            <ChineseCard
                subject="name"
                character="电影"
                pinyin="diàn yǐng"
                translation="films">
            </ChineseCard>
        </DetectionCard>
        <DetectionCard subject="top_4">
            <div class="mb-6">
                <p class="font-serif text-lg text-ink/60 leading-relaxed">
                    some of my all-time favorite pieces of cinema.
                </p>
            </div>
            
            <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
                {topFilms.map((film) => (
                  <div class="group relative flex flex-col">
                    <div class="aspect-2/3 w-full overflow-hidden border border-ink/10 bg-ink/5 mb-3">
                      <img src={film.poster} alt={film.title} class="w-full h-full object-cover" />
                    </div>
                    <div class="font-mono text-sm text-ink/70 tracking-wider">
                      {film.title} <span class="text-ink/40">({film.year})</span>
                    </div>
                  </div>
                ))}
            </div>
        </DetectionCard>
        <DetectionCard subject="links">
            <div class="mb-6">
                <p class="font-serif text-lg text-ink/60 leading-relaxed">
                    go check my recent watch here!
                </p>
            </div>
            <a href={`https://letterboxd.com/${LETTERBOXD_USER}`} target="_blank" class="inline-flex items-center gap-2 font-mono text-[13px] text-ink/60 hover:text-ink tracking-wider transition-all duration-200 group">
                <svg class="w-3 h-3 transition-transform duration-200 group-hover:translate-x-0.5 group-hover:-translate-y-0.5" viewBox="0 0 10 10" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="1" y1="9" x2="9" y2="1"/><polyline points="3,1 9,1 9,7"/></svg>
                letterboxd
            </a>
        </DetectionCard>
    </ContentLayout>
</MainLayout>