---
import MainLayout from "../../layouts/MainLayout.astro";
import { getCollection, render } from "astro:content";
import { stackUrls } from "../../data/stacksUrls";
import { Image } from "astro:assets";
import generateSlug from "../../lib/generateSlug";

export async function getStaticPaths() {
  const projects = await getCollection("projects");
  return projects.map((project) => ({
    params: { slug: generateSlug(project.data.name) },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content, headings } = await render(project);
const hasHeadings = headings && headings.length > 0;
---

<MainLayout
  title={project.data.name}
  description={project.data.description}
  image={project.data.image}
  type="article"
>
  <section class="flex flex-col justify-start py-6 px-10 gap-10">
    <h1 class="split font-family-playfair text-5xl">{project.data.name}</h1>
    <hr class="line-works border-t border-current opacity-20 my-0" />
    <div class="flex gap-10 items-start">
        <!-- SIDEBAR (desktop only) -->
        <aside class="hidden md:flex flex-col w-74 shrink-0 sticky top-10">
            {hasHeadings && (
            <div class="mb-4">
                <p class="split-project text-[12px] uppercase tracking-widest text-neutral-400 mb-3">On this page</p>
                <nav class="flex flex-col gap-1">
                  {headings.map((h) => (
                    <div class="project-slide">
                      <a
                        href={`#${h.slug}`}
                        class="block text-[14px] text-neutral-600 leading-snug transition-all duration-200 ease-out hover:text-black hover:translate-x-0.5"
                        style={`padding-left: ${(h.depth - 1) * 16}px;`}
                      >
                        {h.text}
                      </a>
                    </div>
                  ))}
                </nav>
                <hr class="line-works border-t border-neutral-300 my-4" />
            </div>
            )}

            <div class="mb-4">
            <p class="split-project text-[12px] uppercase tracking-widest text-neutral-400 mb-2">Stack</p>
            <div class="flex flex-wrap gap-2">
                {project.data.stack.map((tech: string) => (
                <div class="project-slide">
                    <a
                        href={stackUrls[tech]}
                        target="_blank"
                        class="inline-flex items-center rounded-full border px-3 py-1 select-none text-sm hover:bg-neutral-100 transition duration-300"
                    >
                        {tech}
                    </a>
                </div>
                ))}
            </div>
            </div>

            <hr class="line-works border-t border-neutral-300 my-3" />

            <div class="mb-4">
                <p class="split-project text-[12px] uppercase tracking-widest text-neutral-400 mb-1">Date</p>
                <p class="project-slide text-sm capitalize text-neutral-500">{project.data.date}</p>
            </div>

            <hr class="line-works border-t border-neutral-300 my-3" />

            <div class="flex flex-row gap-2">
            {project.data.github && (
                <a
                href={project.data.github}
                target="_blank"
                class="project-slide flex items-center gap-1.5 text-sm text-neutral-400 hover:text-black transition-colors group w-fit"
                >
                <svg class="w-2.5 h-2.5 group-hover:translate-x-0.5 group-hover:-translate-y-0.5 transition-transform" viewBox="0 0 10 10" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="1" y1="9" x2="9" y2="1" /><polyline points="3,1 9,1 9,7" /></svg>
                GitHub
                </a>
            )}
            {project.data.live_link && (
                <a
                href={project.data.live_link}
                target="_blank"
                class="project-slide flex items-center gap-1.5 text-sm text-neutral-400 hover:text-black transition-colors group w-fit"
                >
                <svg class="w-2.5 h-2.5 group-hover:translate-x-0.5 group-hover:-translate-y-0.5 transition-transform" viewBox="0 0 10 10" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="1" y1="9" x2="9" y2="1" /><polyline points="3,1 9,1 9,7" /></svg>
                Live
                </a>
            )}
            </div>
        </aside>

        <!-- MAIN CONTENT -->
        <div class="project-detail flex-1 min-w-0">
            {project.data.image ? (
            <Image
                src={project.data.image}
                loading="eager"
                fetchpriority="high"
                decoding="sync"
                alt={`${project.data.name} preview`}
                class="w-full border border-neutral-200 h-52 object-cover object-top rounded-sm mb-6"
            />
            ) : (
            <div class="w-full h-48 bg-neutral-100 rounded-sm mb-6"></div>
            )}

            <!-- mobile meta -->
            <div class="md:hidden mb-6 space-y-4">
                <div class="flex flex-wrap gap-2">
                    {project.data.stack.map((tech: string) => (
                    <div class="project-detail">
                        <a
                            href={stackUrls[tech]}
                            target="_blank"
                            class="inline-flex items-center rounded-full border px-3 py-1 select-none text-sm hover:bg-neutral-100 transition duration-300"
                        >
                            {tech}
                        </a>
                    </div>
                    ))}
                </div>

                <hr class="border-t border-neutral-100" />

                <div class="flex justify-between items-center">
                    <span class="text-sm capitalize text-neutral-400">{project.data.date}</span>
                    <div class="flex gap-4">
                    {project.data.github && (
                        <a
                        href={project.data.github}
                        target="_blank"
                        class="project-detail flex items-center gap-1 text-sm text-neutral-400 hover:text-black transition-colors group"
                        >
                        <svg class="w-2.5 h-2.5 group-hover:translate-x-0.5 group-hover:-translate-y-0.5 transition-transform" viewBox="0 0 10 10" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="1" y1="9" x2="9" y2="1" /><polyline points="3,1 9,1 9,7" /></svg>
                        GitHub
                        </a>
                    )}
                    {project.data.live_link && (
                        <a
                        href={project.data.live_link}
                        target="_blank"
                        class="project-detail flex items-center gap-1 text-sm text-neutral-400 hover:text-black transition-colors group"
                        >
                        <svg class="w-2.5 h-2.5 group-hover:translate-x-0.5 group-hover:-translate-y-0.5 transition-transform" viewBox="0 0 10 10" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="1" y1="9" x2="9" y2="1" /><polyline points="3,1 9,1 9,7" /></svg>
                        Live
                        </a>
                    )}
                    </div>
                </div>

            </div>

            <article class="project-detail prose prose-sm **:text-[15px] max-w-none">
                <Content />
            </article>
        </div>
    </div>
    {hasHeadings && (
        <>
            <div id="toc-backdrop" class="md:hidden fixed inset-0 z-40 hidden" onclick="document.getElementById('toc-pop').classList.add('hidden'); this.classList.add('hidden')"></div>
            <div id="toc-pop" class="md:hidden hidden fixed bottom-16 right-5 z-50 bg-white border border-neutral-200 rounded-xl shadow-lg overflow-hidden min-w-max">
                <nav class="flex flex-col max-h-64 overflow-y-auto py-1">
                    {headings.map((h) => (
                        <a href={`#${h.slug}`}
                            onclick="document.getElementById('toc-pop').classList.add('hidden'); document.getElementById('toc-backdrop').classList.add('hidden')"
                            class="text-sm text-neutral-500 hover:text-black hover:bg-neutral-50 transition-colors py-2 px-4 whitespace-nowrap"
                            style={`padding-left: ${(h.depth - 1) * 16}px;`}>
                                {h.text}
                            </a>
                    ))}
                </nav>
            </div>
            <button
                onclick="document.getElementById('toc-pop').classList.toggle('hidden'); document.getElementById('toc-backdrop').classList.toggle('hidden')"
                class="md:hidden on-this-page fixed bottom-5 right-5 z-50 flex items-center gap-1.5 bg-black text-white text-xs px-3 py-2 rounded-full shadow-md hover:bg-neutral-800 transition-colors"
            >
                <svg class="w-3 h-3" viewBox="0 0 10 10" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="1" y1="2" x2="9" y2="2"/><line x1="1" y1="5" x2="7" y2="5"/><line x1="1" y1="8" x2="5" y2="8"/></svg>
                On this page
            </button>
        </>
    )}
  </section>
</MainLayout>
