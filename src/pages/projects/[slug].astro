---
import BreadCrumbs from "../../components/BreadCrumbs.astro";
import ContentLayout from "../../layouts/ContentLayout.astro";
import DetectionCard from "../../layouts/DetectionCard.astro";
import MainLayout from "../../layouts/MainLayout.astro";
import BackToTop from "../../components/miscellaneous/BackToTop.astro";

import { getCollection, render } from "astro:content";
import { stackUrls } from "../../data/stacksUrls";
import { Image } from "astro:assets";

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project }
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);
---

<MainLayout
    title={project.data.name}
    description={project.data.description}
    image={project.data.image}
    type="article"
    >
    <ContentLayout>
        <BreadCrumbs current={project.data.name}/>
        <DetectionCard subject="details">
            {project.data.image ? (
                <Image src={project.data.image} loading="eager" decoding="sync" alt={`${project.data.name} preview`} class="w-full border border-ink/30 h-52 object-cover object-top rounded-sm mb-5"/>
            ) : (
                <div class="w-full h-48 bg-ink rounded-sm mb-5"></div>
            )}
            <div class="flex flex-col gap-1 mb-5">
                <div class="flex flex-col gap-3">
                    <h2 class="font-serif text-2xl text-ink tracking-tight">{project.data.name}</h2>
                    {project.data.github && (
                        <a href={project.data.github} target="_blank" class="flex items-center gap-2 font-mono text-[13px] text-ink/60 hover:text-ink tracking-wider transition-all duration-200 group w-fit">
                            <svg class="w-3 h-3 transition-transform duration-200 group-hover:translate-x-0.5 group-hover:-translate-y-0.5" viewBox="0 0 10 10" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="1" y1="9" x2="9" y2="1"/><polyline points="3,1 9,1 9,7"/></svg>
                            github
                        </a>
                    )}
                </div>
            </div>

            <!-- stack -->
            <div class="flex flex-wrap gap-x-2 gap-y-1 mb-8">
                {project.data.stack.map((s: string) => (
                    stackUrls[s] ? (
                        <a href={stackUrls[s]} target="_blank" class="font-mono text-[15px] border py-0.5 px-2 text-accent/60 hover:text-accent tracking-wide transition-colors duration-200">{s}</a>
                    ) : (
                        <span class="font-mono text-[15px] text-accent/60 tracking-wide">{s}</span>
                    )
                ))}
            </div>

            <hr class="border-t-[0.5px] border-ink/15 mb-8"/>

            <!-- mdx body -->
            <div class="mdx-content">
                <Content/>
            </div>
        </DetectionCard>
        <BackToTop/>
    </ContentLayout>
</MainLayout>
