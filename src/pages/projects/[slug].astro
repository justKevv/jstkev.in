---
import BreadCrumbs from "../../components/BreadCrumbs.astro";
import ContentLayout from "../../layouts/ContentLayout.astro";
import DetectionCard from "../../layouts/DetectionCard.astro";
import MainLayout from "../../layouts/MainLayout.astro";
import { getCollection, render } from "astro:content";
import { stackUrls } from "../../data/stacksUrls";
import BackToTop from "../../components/miscellaneous/BackToTop.astro";
import { Image } from "astro:assets";

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project }
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);
---

<MainLayout>
    <ContentLayout>
        <BreadCrumbs current={project.data.name}/>
        <DetectionCard subject="details">
            {project.data.image ? (
                <Image src={project.data.image} loading="eager" decoding="sync" alt={`${project.data.name} preview`} class="w-full border  border-ink/30 h-48 object-cover object-top rounded-sm mb-5"/>
            ) : (
                <div class="w-full h-48 bg-ink rounded-sm mb-5"></div>
            )}
            
            <div class="flex flex-col gap-1 mb-5">
                <div class="flex items-center justify-between">
                    <div class="flex items-center gap-3">
                        <h2 class="font-serif text-2xl text-ink tracking-tight">{project.data.name}</h2>
                        {project.data.github && (
                            <a href={project.data.github} target="_blank" aria-label="View on GitHub" class="text-ink/40 hover:text-ink/70 transition-colors duration-200">
                                <svg class="w-6 h-6" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.477 2 2 6.477 2 12c0 4.418 2.865 8.166 6.839 9.489.5.092.682-.217.682-.482 0-.237-.009-.868-.013-1.703-2.782.604-3.369-1.34-3.369-1.34-.454-1.156-1.11-1.464-1.11-1.464-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0 1 12 6.836a9.59 9.59 0 0 1 2.504.337c1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.203 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.741 0 .267.18.578.688.48C19.138 20.163 22 16.418 22 12c0-5.523-4.477-10-10-10z"/></svg>
                            </a>
                        )}
                    </div>
                </div>
            </div>

            <!-- stack -->
            <div class="flex flex-wrap gap-x-2 gap-y-1 mb-8">
                {project.data.stack.map((s: string) => (
                    stackUrls[s] ? (
                        <a href={stackUrls[s]} target="_blank" class="font-mono text-[15px] border py-0.5 px-2 text-accent/60 hover:text-accent tracking-wide transition-colors duration-200">{s}</a>
                    ) : (
                        <span class="font-mono text-[15px] text-accent/60 tracking-wide">{s}</span>
                    )
                ))}
            </div>

            <hr class="border-t-[0.5px] border-ink/15 mb-8"/>

            <!-- mdx body -->
            <div class="mdx-content">
                <Content/>
            </div>
        </DetectionCard>
        <BackToTop/>
    </ContentLayout>
</MainLayout>