---
import MainLayout from "../layouts/MainLayout.astro";
import Background from "../components/Background.astro";
import ContentLayout from "../layouts/ContentLayout.astro";
import DetectionCard from '../layouts/DetectionCard.astro';
import ProjectsCard from '../components/cards/ProjectsCard.astro';
import BreadCrumbs from '../components/BreadCrumbs.astro';
import BackToTop from '../components/miscellaneous/BackToTop.astro';

import { projects } from '../data/projects';
---

<MainLayout>
    <ContentLayout>
        <BreadCrumbs current="projects"/>
        <DetectionCard subject="projects">
            {projects.map((project) => (
                <ProjectsCard
                    name={project.name}
                    description={project.description}
                    stack={project.stack}
                    github={project.github}
                    link={project.link}
                    date={project.date}
                />
            ))}
        </DetectionCard>
        <BackToTop/>
    </ContentLayout>
</MainLayout>