---
import '../styles/global.css'
import MainLayout from "../layouts/MainLayout.astro";
import Background from "../components/Background.astro";
import ContentLayout from "../layouts/ContentLayout.astro";
import DetectionCard from '../layouts/DetectionCard.astro';
import ProjectsCard from '../components/cards/ProjectsCard.astro';

import { projects } from '../data/projects';
---

<MainLayout>
    <ContentLayout>
        <div class="flex items-center justify-between font-mono text-[12px] tracking-widest text-[#1a1a1a]/40 uppercase mt-8 mb-12">
            <div class="flex items-center gap-2">
                <a href="/" class="hover:text-[#1a1a1a] transition-colors duration-200">jst.kevv</a>
                <span>/</span>
                <span class="text-[#1a1a1a]">projects</span>
            </div>
            <a href="/" class="flex items-center gap-2 hover:text-[#1a1a1a] transition-all duration-200 group">
                <svg class="w-3 h-3 rotate-180 transition-transform duration-200 group-hover:-translate-x-0.5" viewBox="0 0 10 10" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="1" y1="9" x2="9" y2="1"/>
                    <polyline points="3,1 9,1 9,7"/>
                </svg>
                back
            </a>
        </div>
        <DetectionCard subject="projects">
            {projects.map((project) => (
                <ProjectsCard
                    name={project.name}
                    description={project.description}
                    stack={project.stack}
                    github={project.github}
                    link={project.link}
                    date={project.date}
                />
            ))}
        </DetectionCard>
        <div class="flex items-center justify-center font-mono text-[12px] tracking-widest text-[#1a1a1a]/70 mt-4 mb-12">
            <p>you are at the end, buddy</p>
        </div>
    </ContentLayout>
    <Background/>
</MainLayout>