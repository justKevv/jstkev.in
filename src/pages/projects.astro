---
import MainLayout from "../layouts/MainLayout.astro";
import Background from "../components/Background.astro";
import ContentLayout from "../layouts/ContentLayout.astro";
import DetectionCard from "../layouts/DetectionCard.astro";
import ProjectsCard from "../components/cards/ProjectsCard.astro";
import BreadCrumbs from "../components/BreadCrumbs.astro";
import BackToTop from "../components/miscellaneous/BackToTop.astro";

import { getCollection, type CollectionEntry } from "astro:content";
const projects = await getCollection("projects");
type Project = CollectionEntry<"projects">;
---

<MainLayout>
    <ContentLayout>
        <BreadCrumbs current="projects" />
        <DetectionCard subject="projects">
            {
                projects.map((project: Project) => (
                    <ProjectsCard
                        name={project.data.name}
                        description={project.data.description}
                        stack={project.data.stack}
                        github={project.data.github}
                        live_link={project.data.live_link}
                        date={project.data.date}
                        content_link={`projects/${project.data.name}`}
                    />
                ))
            }
        </DetectionCard>
        <BackToTop />
    </ContentLayout>
</MainLayout>
