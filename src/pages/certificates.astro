---
import MainLayout from "../layouts/MainLayout.astro";
import { Image } from 'astro:assets';
import { certifications } from "../data/certifications";
---

<MainLayout>
    <section class="flex flex-col justify-start py-6 px-10 gap-8">
        <h1 class="split font-family-playfair text-5xl">Certificates</h1>
        <hr class="line-works border-t border-current opacity-20 my-0" />

        <div class="columns-2 xl:columns-3 gap-2 [column-fill:balance]">
            {Object.entries(certifications.grouped).flatMap(([groupName, certs]) =>
              certs.map(({ image, caption }) => (
                <figure class="project-card group relative mb-3 break-inside-avoid overflow-hidden rounded-sm">
                  <span class="absolute top-2 left-2 z-10 inline-flex items-center rounded-full border border-black/15 bg-white/85 px-2.5 py-1 text-[12px] tracking-widest text-black backdrop-blur-sm">
                    {groupName}
                  </span>

                  <Image
                    src={image}
                    alt={caption}
                    quality={80}
                    data-lightbox
                    data-src={image.src}
                    loading="eager"
                    data-caption={caption}
                    class="w-full h-auto object-cover border rounded-sm"
                  />

                  <figcaption class="pointer-events-none absolute inset-x-0 bottom-0 z-10 bg-black/80 px-3 py-2 text-[13px] tracking-wide text-white/90 opacity-100 translate-y-0 md:opacity-0 md:translate-y-full md:transition-all md:duration-250 md:ease-out md:group-hover:opacity-100 md:group-hover:translate-y-0">
                    {caption}
                  </figcaption>
                </figure>
              ))
            )}
        </div>

    </section>
</MainLayout>
