---
import MainLayout from '../layouts/MainLayout.astro';
const year = new Date().getFullYear() - 2024;
---

<MainLayout>
    <section class="h-full min-h-0 flex flex-col justify-between items-center py-6 gap-3">
        <h1 class="split text-[40px] sm:text-[47px] md:text-8xl lg:text-9xl text-center font-family-playfair">Kevin Bramasta</h1>
        <p class="split-paraf text-[11px] md:text-[13.5px] lg:text-[15px] max-w-xs md:max-w-xl lg:max-w-3xl text-center">I'm Kevin&mdash;obviously, a developer from Malang, Indonesia (currently in China) with {year}+ years in software development and machine learning.
        Most days, I'm coding, but sometimes I overthink stuff at 3 AM. </p>
        <canvas id="hero-canvas" class="hero-canvas cursor-grab w-full lg:w-[40%] flex-1 min-h-0 block"></canvas>
    </section>
</MainLayout>

<script>
  import "../scripts/scene.js";
</script>
