---
import SplashScreen from '../components/SplashScreen.astro';
import MainLayout from '../layouts/MainLayout.astro';
import ContentLayout from "../layouts/ContentLayout.astro";
import DetectionCard from '../layouts/DetectionCard.astro';
import WorksCard from '../components/cards/WorksCard.astro';
import ProjectsCard from '../components/cards/ProjectsCard.astro';

import { works } from '../data/works';
import { featured, type Project } from '../data/projects';
import generateSlug from '../lib/generateSlug';

import { EMAIL, GITHUB_URL, LINKEDIN_URL } from '../config';
---

<MainLayout>
    <SplashScreen/>
    <ContentLayout>
        <DetectionCard subject="jst.kevv">
            <p id="hero-wen" class="text-accent text-xl inline-block" style="opacity: 0;">文</p>
            <h1 class="text-4xl text-ink font-serif leading">Kevin Bramasta Arvyto Wardhana</h1>
            <hr class="border-t-[0.5px] border-ink/20 my-3 w-8 h-0.5">
            <p class="font-serif text-lg max-w-96 text-ink/70 leading-7">
                building for the web, training models, and figuring out the design engineer thing along the way.
            </p>
        </DetectionCard>
        <DetectionCard subject="about">
            <div class="space-y-3 text-ink/70 font-serif text-lg leading-7">
                <p>grew up messing around with cameras and editing software before i even knew what a terminal was. then i found code and kind of never looked back. though the design brain never really switched off.</p>
                <p>these days i'm mostly into <span class="text-accent">ml</span>, building <span class="text-accent">backends</span>, and learning whatever looks interesting. <span class="text-accent">golang</span>, <span class="text-accent">iot</span>, <span class="text-accent">astro</span>, yeah i know it's a lot.</p>
                <p><span class="text-danger">indonesia</span>-based (currently in china), chronically curious, occasionally overthinks life at 2am.</p>
            </div>
        </DetectionCard>
        <DetectionCard subject="works">
            {works.map((work) => (
              <WorksCard
                  company={work.company}
                  role={work.role}
                  stack={work.stack}
                  type={work.type}
                  date={work.date}
                  location={work.location}
                  highlights={work.highlights}
              />
            ))}
        </DetectionCard>
        <DetectionCard subject="projects">
            {featured.length >= 3 ? (
                <>
                    {featured.slice(0, 3).map((project: Project) => (
                      <ProjectsCard
                          name={project.data.name}
                          description={project.data.description}
                          image={project.data.image}
                          stack={project.data.stack}
                          github={project.data.github}
                          live_link={project.data.live_link}
                          date={project.data.date}
                          content_link={`projects/${generateSlug(project.data.name)}`}
                      />
                    ))}
                    <a href="/projects" class="flex items-center justify-center font-mono text-[13px] tracking-wider text-ink/70 border border-ink/20 py-2 transition-all duration-300 hover:text-ink hover:border-ink/70 hover:bg-ink/3 group">
                        <span>see more projects</span>
                        <svg class="w-3 h-3 ml-2 transition-transform duration-300 group-hover:translate-x-0.5 group-hover:-translate-y-0.5" viewBox="0 0 10 10" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="1" y1="9" x2="9" y2="1"/><polyline points="3,1 9,1 9,7"/></svg>
                    </a>

                </>
            ) : (
              featured.map((project: Project) => (
                  <ProjectsCard
                      name={project.data.name}
                      description={project.data.description}
                      image={project.data.image}
                      stack={project.data.stack}
                      github={project.data.github}
                      live_link={project.data.live_link}
                      date={project.data.date}
                      content_link={`projects/${generateSlug(project.data.name)}`}
                  />
              ))
            )}
        </DetectionCard>
        <DetectionCard subject="certifications">
          <a href="/certifications" class="w-full flex items-center text-[13px] tracking-widest justify-center py-3 text-ink/70 border border-ink/20 font-mono hover:text-ink hover:bg-ink/3 hover:border-ink/70 transition-colors duration-200 group">
              <span>see all certifications</span>
              <svg class="w-3 h-3 ml-2 transition-transform duration-300 group-hover:translate-x-0.5 group-hover:-translate-y-0.5" viewBox="0 0 10 10" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="1" y1="9" x2="9" y2="1"/><polyline points="3,1 9,1 9,7"/></svg>
          </a>
        </DetectionCard>
        <DetectionCard subject="contacts">
            <div class="flex flex-col gap-2">
              <p class="font-serif text-2xl sm:text-3xl text-ink tracking-tight leading-snug">
                got something in mind? let's talk.
              </p>
              <p class="font-serif text-lg text-ink/65 leading-relaxed mt-2 max-w-xs">
                open to freelance, collabs, or just a good conversation.
              </p>
            </div>
            <div class="flex flex-col sm:flex-row gap-4 mt-5">
                <!-- email -->
                <a href={`mailto:${EMAIL}`} target="_blank" class="flex items-center gap-2 font-mono text-[13px] text-ink/60 hover:text-ink tracking-wider transition-all duration-200 group">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-mail-icon lucide-mail w-4 h-4"><path d="m22 7-8.991 5.727a2 2 0 0 1-2.009 0L2 7"/><rect x="2" y="4" width="20" height="16" rx="2"/></svg>
                  email
                </a>

                <!-- github -->
                <a href={GITHUB_URL} target="_blank" class="flex items-center gap-2 font-mono text-[13px] text-ink/60 hover:text-ink tracking-wider transition-all duration-200 group">
                  <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/>
                  </svg>
                  github
                </a>

                <!-- linkedin -->
                <a href={LINKEDIN_URL} target="_blank" class="flex items-center gap-2 font-mono text-[13px] text-ink/60 hover:text-ink tracking-wider transition-all duration-200 group">
                  <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                  </svg>
                  linkedin
                </a>

                <!-- resume -->
                <a href="/kevin_bramasta_softwaredeveloper.pdf" target="_blank" class="flex items-center gap-2 font-mono text-[13px] text-ink/60 hover:text-ink tracking-wider transition-all duration-200 group">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-file-text-icon lucide-file-text w-4 h-4"><path d="M6 22a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h8a2.4 2.4 0 0 1 1.704.706l3.588 3.588A2.4 2.4 0 0 1 20 8v12a2 2 0 0 1-2 2z"/><path d="M14 2v5a1 1 0 0 0 1 1h5"/><path d="M10 9H8"/><path d="M16 13H8"/><path d="M16 17H8"/></svg>
                    resume.pdf
                </a>
            </div>

            <div class="pt-8 flex justify-start items-center">
              <span class="font-mono text-[14px] text-ink/60 tracking-widest">文 · {new Date().getFullYear()}</span>
            </div>
        </DetectionCard>
    </ContentLayout>
</MainLayout>
