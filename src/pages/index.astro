---
import SplashScreen from '../components/SplashScreen.astro';
import MainLayout from '../layouts/MainLayout.astro';
import ContentLayout from "../layouts/ContentLayout.astro";
import DetectionCard from '../layouts/DetectionCard.astro';
import WorksCard from '../components/cards/WorksCard.astro';
import ProjectsCard from '../components/cards/ProjectsCard.astro';

import { works } from '../data/works';
import { getCollection, type CollectionEntry } from 'astro:content';
const projects = await getCollection('projects');
const sorted = projects.sort((first, second) => first.data.order - second.data.order);
type Project = CollectionEntry<'projects'>;

import { EMAIL, GITHUB_URL, LINKEDIN_URL } from '../config';
---

<MainLayout>
    <SplashScreen/>
    <ContentLayout>
        <DetectionCard subject="jst.kevv">
            <p id="hero-wen" class="text-accent/60 text-xl inline-block" style="opacity: 0;">文</p>
            <h1 class="text-4xl text-ink font-serif leading">Kevin Bramasta Arvyto Wardhana</h1>
            <hr class="border-t-[0.5px] border-ink opacity-20 my-3 w-8 h-0.5">
            <p class="font-serif text-lg max-w-96 text-ink opacity-60 leading-7">
                building for the web, training models, and figuring out the design engineer thing along the way.
            </p>
        </DetectionCard>
        <DetectionCard subject="about">
            <div class="space-y-3 text-ink opacity-60 font-serif text-lg leading-7">
                <p>grew up messing around with cameras and editing software before i even knew what a terminal was. then i found code and kind of never looked back. though the design brain never really switched off.</p>
                <p>these days i'm mostly into <span class="text-accent">ml</span>, building <span class="text-accent">backends</span>, and learning whatever looks interesting. <span class="text-accent">golang</span>, <span class="text-accent">iot</span>, <span class="text-accent">astro</span>, yeah i know it's a lot.</p>
                <p>chronically curious, occasionally overthinks life at 2am.</p>
            </div>
        </DetectionCard>
        <DetectionCard subject="works">
            {works.map((work) => (
              <WorksCard
                  company={work.company}
                  role={work.role}
                  stack={work.stack}
                  type={work.type}
                  date={work.date}
                  location={work.location}
                  highlights={work.highlights}
              />
            ))}
        </DetectionCard>
        <DetectionCard subject="projects">
            {sorted.length > 3 ? (
                <>
                    {sorted.slice(0, 3).map((project: Project) => (
                      <ProjectsCard
                          name={project.data.name}
                          description={project.data.description}
                          image={project.data.image}
                          stack={project.data.stack}
                          github={project.data.github}
                          live_link={project.data.live_link}
                          date={project.data.date}
                          content_link={`projects/${project.slug}`}
                      />
                    ))}
                    <a href="/projects" class="flex items-center justify-center font-mono text-[13px] tracking-wider text-ink/60 border border-ink/20 py-2 transition-all duration-300 hover:text-ink hover:border-ink/60 hover:bg-ink/3 group">
                        <span>see more projects</span>
                        <svg class="w-3 h-3 ml-2 transition-transform duration-300 group-hover:translate-x-0.5 group-hover:-translate-y-0.5" viewBox="0 0 10 10" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="1" y1="9" x2="9" y2="1"/><polyline points="3,1 9,1 9,7"/></svg>
                    </a>

                </>
            ) : (
              sorted.map((project: Project) => (
                  <ProjectsCard
                      name={project.data.name}
                      description={project.data.description}
                      image={project.data.image}
                      stack={project.data.stack}
                      github={project.data.github}
                      live_link={project.data.live_link}
                      date={project.data.date}
                      content_link={`projects/${project.slug}`}
                  />
              ))
            )}

        </DetectionCard>
        <DetectionCard subject="contacts">
            <div class="flex flex-col gap-2">
              <p class="font-serif text-2xl sm:text-3xl text-ink tracking-tight leading-snug">
                got something in mind? let's talk.
              </p>
              <p class="font-serif text-lg text-ink/45 leading-relaxed mt-2 max-w-xs">
                open to freelance, collabs, or just a good conversation.
              </p>
            </div>
            <div class="flex flex-col sm:flex-row gap-4 mt-5">
                <a href={`mailto:${EMAIL}`} target="_blank" class="flex items-center gap-2 font-mono text-[13px] text-ink/60 hover:text-ink tracking-wider transition-all duration-200 group">
                <svg class="w-3 h-3 transition-transform duration-200 group-hover:translate-x-0.5 group-hover:-translate-y-0.5" viewBox="0 0 10 10" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="1" y1="9" x2="9" y2="1"/><polyline points="3,1 9,1 9,7"/></svg>
                email
              </a>
              <a href={GITHUB_URL} target="_blank" class="flex items-center gap-2 font-mono text-[13px] text-ink/60 hover:text-ink tracking-wider transition-all duration-200 group">
                <svg class="w-3 h-3 transition-transform duration-200 group-hover:translate-x-0.5 group-hover:-translate-y-0.5" viewBox="0 0 10 10" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="1" y1="9" x2="9" y2="1"/><polyline points="3,1 9,1 9,7"/></svg>
                github
              </a>
              <a href={LINKEDIN_URL} target="_blank" class="flex items-center gap-2 font-mono text-[13px] text-ink/60 hover:text-ink tracking-wider transition-all duration-200 group">
                <svg class="w-3 h-3 transition-transform duration-200 group-hover:translate-x-0.5 group-hover:-translate-y-0.5" viewBox="0 0 10 10" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="1" y1="9" x2="9" y2="1"/><polyline points="3,1 9,1 9,7"/></svg>
                linkedin
              </a>
              <a href="/resume.pdf" target="_blank" class="flex items-center gap-2 font-mono text-[13px] text-ink/60 hover:text-ink tracking-wider transition-all duration-200 group">
                <svg class="w-3 h-3" viewBox="0 0 10 10" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="1" y1="9" x2="9" y2="1"/><polyline points="3,1 9,1 9,7"/></svg>
                resume.pdf
              </a>
            </div>
          
            <div class="pt-8 flex justify-start items-center">
              <span class="font-mono text-[14px] text-ink/60 tracking-widest">文 · {new Date().getFullYear()}</span>
            </div>
        </DetectionCard>
    </ContentLayout>
</MainLayout>

<script is:inline>
  if ('scrollRestoration' in history) {
    history.scrollRestoration = 'manual';
  }
  window.scrollTo(0, 0)
</script>