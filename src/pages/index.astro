---
import '../styles/global.css'
import Background from '../components/Background.astro';
import SplashScreen from '../components/SplashScreen.astro';
import MainLayout from '../layouts/MainLayout.astro';
import ContentLayout from "../layouts/ContentLayout.astro";
import DetectionCard from '../layouts/DetectionCard.astro';

globalThis.__detectionCount = 0;
---

<MainLayout>
    <!-- <SplashScreen/> -->
    <ContentLayout>
        <DetectionCard subject="jst.kevv">
            <p class="text-[#1a1a1a] text-lg opacity-35">文</p>
            <h1 class="text-3xl text-[#1a1a1a] font-serif leading">Kevin Bramasta Arvyto Wardhana</h1>
            <h3 class="text-sm opacity-35 tracking-widest text-[#1a1a1a] font-serif mt-2">design engineer wannabe</h3>
            <hr class="border-t-[0.5px] border-[#1a1a1a] opacity-20 my-3 w-8 h-0.5">
            <p class="font-serif text-[16px] max-w-96 text-[#1a1a1a] opacity-60 leading-7">
                one thing led to another — ml, code, design, you name it. always picking up something new, always figuring it out as i go. having fun with it though.
            </p>
        </DetectionCard>
        <DetectionCard subject="about">
            <div class="space-y-3 text-[#1a1a1a] opacity-60 font-serif text-[16px] leading-7">
                <p>grew up messing around with cameras and editing software before i even knew what a terminal was. then i found code and kind of never looked back — though the design brain never really switched off.</p>
                <p>these days i'm mostly into ml, building backends, and learning whatever looks interesting. golang, iot, astro — yeah i know it's a lot. i just can't help it.</p>
                <p>indonesia-based, chronically curious, occasionally overthinks life at 2am.</p>
            </div>
        </DetectionCard>
    </ContentLayout>
	<Background />
</MainLayout>
