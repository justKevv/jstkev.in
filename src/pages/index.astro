---
import '../styles/global.css'
import Background from '../components/Background.astro';
import SplashScreen from '../components/SplashScreen.astro';
import MainLayout from '../layouts/MainLayout.astro';
import ContentLayout from "../layouts/ContentLayout.astro";
import DetectionCard from '../layouts/DetectionCard.astro';
import WorksCard from '../components/cards/WorksCard.astro';
import ProjectsCard from '../components/cards/ProjectsCard.astro';

import { works } from '../data/works';
import { projects } from '../data/projects';

import { EMAIL, GITHUB_URL, LINKEDIN_URL } from '../config';

globalThis.__detectionCount = 0;
---

<MainLayout>
    <SplashScreen/>
    <ContentLayout>
        <DetectionCard subject="jst.kevv">
            <p id="hero-wen" class="text-[#EA580C]/60 text-xl inline-block" style="opacity: 0;">文</p>
            <h1 class="text-4xl text-[#1a1a1a] font-serif leading">Kevin Bramasta Arvyto Wardhana</h1>
            <h3 class="text-md opacity-35 tracking-widest text-[#1a1a1a] font-serif mt-2">design engineer wannabe</h3>
            <hr class="border-t-[0.5px] border-[#1a1a1a] opacity-20 my-3 w-8 h-0.5">
            <p class="font-serif text-lg max-w-96 text-[#1a1a1a] opacity-60 leading-7">
                one thing led to another — <span class="text-[#EA580C]">ml</span>, <span class="text-[#EA580C]">code</span>, <span class="text-[#EA580C]">design</span>, you name it. always picking up something new, always figuring it out as i go. having fun with it though.
            </p>
        </DetectionCard>
        <DetectionCard subject="about">
            <div class="space-y-3 text-[#1a1a1a] opacity-60 font-serif text-lg leading-7">
                <p>grew up messing around with cameras and editing software before i even knew what a terminal was. then i found code and kind of never looked back — though the design brain never really switched off.</p>
                <p>these days i'm mostly into <span class="text-[#EA580C]">ml</span>, building <span class="text-[#EA580C]">backends</span>, and learning whatever looks interesting. <span class="text-[#EA580C]">golang</span>, <span class="text-[#EA580C]">iot</span>, <span class="text-[#EA580C]">astro</span> — yeah i know it's a lot. i just can't help it.</p>
                <p><span class="text-[#DC2626]">indonesia</span>-based, chronically curious, occasionally overthinks life at 2am.</p>
            </div>
        </DetectionCard>
        <DetectionCard subject="work">
            {works.map((work) => (
              <WorksCard
                  company={work.company}
                  role={work.role}
                  stack={work.stack}
                  type={work.type}
                  date={work.date}
                  location={work.location}
                  highlights={work.highlights}
              />
            ))}
        </DetectionCard>
        <DetectionCard subject="project">
            {projects.length > 3 ? (
                <>
                    {projects.slice(0, 3).map((project) => (
                        <ProjectsCard
                            name={project.name}
                            description={project.description}
                            stack={project.stack}
                            github={project.github}
                            link={project.link}
                            date={project.date}
                        />
                    ))}
                    <a href="/projects" class="flex items-center justify-center font-mono text-[13px] tracking-wider text-[#1a1a1a]/60 border border-[#1a1a1a]/20 py-2 transition-all duration-300 hover:text-[#1a1a1a] hover:border-[#1a1a1a]/60 hover:bg-[#1a1a1a]/3 group">
                        <span>see more projects</span>
                        <svg class="w-3 h-3 ml-2 transition-transform duration-300 group-hover:translate-x-0.5 group-hover:-translate-y-0.5" viewBox="0 0 10 10" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="1" y1="9" x2="9" y2="1"/><polyline points="3,1 9,1 9,7"/></svg>
                    </a>

                </>
            ) : (
                projects.map((project) => (
                    <ProjectsCard
                        name={project.name}
                        description={project.description}
                        stack={project.stack}
                        github={project.github}
                        link={project.link}
                        date={project.date}
                    />
                ))
            )}

        </DetectionCard>
        <DetectionCard subject="contact">
            <div class="flex flex-col gap-2">
              <p class="font-serif text-2xl sm:text-3xl text-[#1a1a1a] tracking-tight leading-snug">
                got something in mind? let's talk.
              </p>
              <p class="font-serif text-lg text-[#1a1a1a]/45 leading-relaxed mt-2 max-w-xs">
                open to freelance, collabs, or just a good conversation.
              </p>
            </div>
            <div class="flex flex-col sm:flex-row gap-4 mt-5">
                <a href={EMAIL} class="flex items-center gap-2 font-mono text-[13px] text-[#1a1a1a]/50 hover:text-[#1a1a1a] tracking-wider transition-all duration-200 group">
                <svg class="w-3 h-3 transition-transform duration-200 group-hover:translate-x-0.5 group-hover:-translate-y-0.5" viewBox="0 0 10 10" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="1" y1="9" x2="9" y2="1"/><polyline points="3,1 9,1 9,7"/></svg>
                email
              </a>
              <a href={GITHUB_URL} target="_blank" class="flex items-center gap-2 font-mono text-[13px] text-[#1a1a1a]/50 hover:text-[#1a1a1a] tracking-wider transition-all duration-200 group">
                <svg class="w-3 h-3 transition-transform duration-200 group-hover:translate-x-0.5 group-hover:-translate-y-0.5" viewBox="0 0 10 10" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="1" y1="9" x2="9" y2="1"/><polyline points="3,1 9,1 9,7"/></svg>
                github
              </a>
              <a href={LINKEDIN_URL} target="_blank" class="flex items-center gap-2 font-mono text-[13px] text-[#1a1a1a]/50 hover:text-[#1a1a1a] tracking-wider transition-all duration-200 group">
                <svg class="w-3 h-3 transition-transform duration-200 group-hover:translate-x-0.5 group-hover:-translate-y-0.5" viewBox="0 0 10 10" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="1" y1="9" x2="9" y2="1"/><polyline points="3,1 9,1 9,7"/></svg>
                linkedin
              </a>
              <a href="/resume.pdf" target="_blank" class="flex items-center gap-2 font-mono text-[13px] text-[#1a1a1a]/50 hover:text-[#1a1a1a] tracking-wider transition-all duration-200 group">
                <svg class="w-3 h-3" viewBox="0 0 10 10" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="1" y1="9" x2="9" y2="1"/><polyline points="3,1 9,1 9,7"/></svg>
                resume.pdf
              </a>
            </div>
          
            <div class="pt-8 flex justify-start items-center">
              <span class="font-mono text-[12px] text-[#1a1a1a]/60 tracking-widest">文 · {new Date().getFullYear()}</span>
            </div>
        </DetectionCard>
    </ContentLayout>
</MainLayout>

<script is:inline>
  if ('scrollRestoration' in history) {
    history.scrollRestoration = 'manual';
  }
  window.scrollTo(0, 0)
</script>