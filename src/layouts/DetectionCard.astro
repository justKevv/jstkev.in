---
const { subject } = Astro.props;

declare global { var __detectionCount: number; }
const detection_id = String((globalThis.__detectionCount = (globalThis.__detectionCount ?? 0) + 1)).padStart(2, '0')
const bbox = Array.from({length: 4}, () => Math.random().toFixed(3));
---

<section class="relative w-full h-fit z-20 pointer-events-none my-16 mx-auto">
    <!-- top labels -->
    <div class="flex justify-between font-mono text-[12px] tracking-[0.12em] uppercase mb-2">
        <span class="text-ink/60">dtctn_{detection_id} // <span class="font-extrabold text-ink/90">{subject}</span></span>
        <span class="text-ink/60 whitespace-nowrap">conf: <span id="conf">0.97</span></span>
    </div>

    <!-- card body with corner brackets -->
    <div class="relative pointer-events-auto p-4">
        <!-- corner brackets -->
        <div data-corner="tl" class="absolute top-0 left-0 w-5.5 h-5.5 border-ink/70 border-t-[1.8px] border-l-[1.8px]"></div>
        <div data-corner="tr" class="absolute top-0 right-0 w-5.5 h-5.5 border-ink/70 border-t-[1.8px] border-r-[1.8px]"></div>
        <div data-corner="bl" class="absolute bottom-0 left-0 w-5.5 h-5.5 border-ink/70 border-b-[1.8px] border-l-[1.8px]"></div>
        <div data-corner="br" class="absolute bottom-0 right-0 w-5.5 h-5.5 border-ink/70 border-b-[1.8px] border-r-[1.8px]"></div>

        <slot/>
    </div>

    <!-- bottom coords -->
    <div class="flex justify-between font-mono text-[11px] tracking-[0.08em] text-ink/60 pointer-events-none mt-2">
        <span>[{bbox.join(', ')}]</span>
    </div>
</section>
