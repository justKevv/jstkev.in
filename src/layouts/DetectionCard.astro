---
const { subject } = Astro.props;

declare global { var __detectionCount: number; }
const detection_id = String((globalThis.__detectionCount = (globalThis.__detectionCount ?? 0) + 1)).padStart(2, '0')
---

<div class="relative w-full h-fit z-20 pointer-events-none my-8 mx-auto">
    <!-- top labels -->
    <div class="flex justify-between font-mono text-[10px] tracking-[0.12em] text-[#1a1a1a] opacity-40 uppercase mb-2">
        <span>detection_{detection_id} // <b>{subject}</b></span>
        <span>conf: <span id="conf">0.97</span></span>
    </div>
    
    <!-- card body with corner brackets -->
    <div class="relative pointer-events-auto p-4">
        <!-- corner brackets -->
        <div class="absolute top-0 left-0 w-4.5 h-4.5 border-[#1a1a1a] border-t-[1.5px] border-l-[1.5px] opacity-50 animate-pulse-opacity"></div>
        <div class="absolute top-0 right-0 w-4.5 h-4.5 border-[#1a1a1a] border-t-[1.5px] border-r-[1.5px] opacity-50 animate-pulse-opacity"></div>
        <div class="absolute bottom-0 left-0 w-4.5 h-4.5 border-[#1a1a1a] border-b-[1.5px] border-l-[1.5px] opacity-50 animate-pulse-opacity"></div>
        <div class="absolute bottom-0 right-0 w-4.5 h-4.5 border-[#1a1a1a] border-b-[1.5px] border-r-[1.5px] opacity-50 animate-pulse-opacity"></div>

        <slot/>
    </div>
    
    <!-- bottom coords -->
    <div class="flex justify-between font-mono text-[10px] tracking-[0.08em] text-[#1a1a1a] opacity-30 pointer-events-none mt-2 animate-flicker">
        <span>[0.241, 0.118, 0.753, 0.889]</span>
        <span>frame_<span id="frame">0001</span></span>
    </div>
</div>

<script is:inline>
  setInterval(() => {
    if (Math.random() > 0.7) {
      document.getElementById("conf").textContent = (0.94 + Math.random() * 0.05).toFixed(2);
      const f = document.getElementById("frame");
      f.textContent = String(parseInt(f.textContent) + 1).padStart(4, "0");
    }
  }, 1200);
</script>