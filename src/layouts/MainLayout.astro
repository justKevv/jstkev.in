---
import "../styles/global.css";
import SEO from "../components/SEO.astro";
import type { ImageMetadata } from "astro";
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

interface Props {
    title?: string;
    description?: string;
    image?: string | ImageMetadata;
    type?: "website" | "article";
    noindex?: boolean;
}

const { title, description, image, type, noindex } = Astro.props;

globalThis.__detectionCount = 0;
---

<!doctype html>
<html lang="en" class="is-loading">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width" />
        <link rel="icon" type="image/png" sizes="128x128" href="/文.png" />
        <meta name="generator" content={Astro.generator} />
        <script defer is:inline src="https://cloud.umami.is/script.js" data-website-id="67a8fb86-ca7a-40ad-9d0a-828e794826cc"></script>
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
          rel="preload"
          as="style"
          href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&display=swap"
          onload="this.onload=null;this.rel='stylesheet'"
        />
        <noscript>
          <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&display=swap" rel="stylesheet" />
        </noscript>
        <style is:inline>
          html.is-loading .page-content,
          .split,
          .split-paraf,
          .nav-split,
          .footer-line,
          .latest,
          .line-works,
          .project-card,
          .project-detail,
          .work-split,
          .split-project,
          .project-slide,
          .on-this-page,
          #hero-canvas {
            opacity: 0;
            visibility: hidden;
          }
        </style>
        <SEO
            title={title}
            description={description}
            image={image}
            type={type}
            noindex={noindex}
        />
    </head>
    <body class="overflow-hidden">
        <main class="relative w-full max-w-360 mx-auto h-dvh flex flex-col overflow-hidden">
            <div class="page-content flex flex-col min-h-0 flex-1" style="opacity: 0; visibility: hidden;">
                <Navbar />
                <div class="flex-1 min-h-0 overflow-y-auto scroll-smooth">
                    <slot />
                </div>
                <Footer />
            </div>
            <div class="pointer-events-none fixed inset-0 -z-10 bg-[radial-gradient(#e5e7eb_1px,transparent_1px)] bg-size-[16px_16px] mask-[radial-gradient(ellipse_50%_50%_at_50%_50%,#000_70%,transparent_100%)]"></div>
        </main>
    </body>
</html>

<script>
  async function initAnimations() {
    const revealContent = () => {
      document.documentElement.classList.remove('is-loading');
      const pageContent = document.querySelector('.page-content');
      if (pageContent) {
        pageContent.style.removeProperty('opacity');
        pageContent.style.removeProperty('visibility');
      }
    };

    const animationSelectors = [
      '.split',
      '.split-paraf',
      '.nav-split',
      '.footer-line',
      '.latest',
      '.line-works',
      '.project-card',
      '.project-detail',
      '.work-split',
      '.split-project',
      '.on-this-page',
      '.project-slide',
      '#hero-canvas',
    ];

    const shouldAnimate = animationSelectors.some((selector) => document.querySelector(selector));
    if (!shouldAnimate) {
      revealContent();
      return;
    }

    revealContent();

    const runAnimations = async () => {
      const [{ gsap }, { CSSPlugin }] = await Promise.all([
        import('gsap/gsap-core'),
        import('gsap/CSSPlugin'),
      ]);
      gsap.registerPlugin(CSSPlugin);

      // Immediately reveal elements for GSAP control (autoAlpha = opacity + visibility)
      gsap.set(['.split', '.split-paraf', '.nav-split', '.footer-line', '.latest', '.line-works', '.project-card', '.project-detail', '.work-split', '.split-project', '.on-this-page'], { autoAlpha: 1 });
      gsap.set('.project-slide', { willChange: 'transform,opacity' });

      const canvas = document.querySelector('#hero-canvas');
      if (canvas) {
        gsap.set(canvas, { autoAlpha: 0 });
        requestAnimationFrame(() => {
          gsap.to(canvas, {
            autoAlpha: 1,
            duration: 1.1,
            ease: 'power2.out',
            delay: 0.7,
          });
        });
      }

      const needsSplitText = document.querySelector('.split, .split-paraf, .split-project');
      const allowSplitText =
        !window.matchMedia('(prefers-reduced-motion: reduce)').matches &&
        window.innerWidth >= 768;

      if (needsSplitText && allowSplitText) {
        const { SplitText } = await import('gsap/SplitText');
        gsap.registerPlugin(SplitText);

        // Wait for fonts before SplitText so line/chars split is accurate
        await document.fonts.ready;

        SplitText.create('.split', {
          type: 'chars,words',
          autoSplit: true,
          mask: 'lines',
          onSplit: (self) => {
            return gsap.from(self.chars, {
              yPercent: 120,
              opacity: 0,
              duration: 0.8,
              ease: 'power4.out',
              stagger: 0.04,
              delay: 0.5,
            });
          },
        });

        SplitText.create('.split-paraf', {
          type: 'words,lines',
          linesClass: 'line',
          autoSplit: true,
          mask: 'lines',
          onSplit: (self) => {
            return gsap.from(self.lines, {
              duration: 1.1,
              yPercent: 150,
              opacity: 0,
              stagger: 0.08,
              ease: 'expo.out',
              delay: 0.8,
            });
          },
        });

        SplitText.create('.split-project', {
          type: 'words,lines',
          linesClass: 'line',
          autoSplit: true,
          mask: 'lines',
          onSplit: (self) => {
            return gsap.from(self.lines, {
              duration: 1.1,
              yPercent: 150,
              opacity: 0,
              stagger: 0.1,
              ease: 'expo.out',
              delay: 0.5,
            });
          },
        });
      }

      gsap.from('.nav-split', {
        duration: 0.8,
        y: 8,
        opacity: 0,
        scale: 0.6,
        stagger: 0.08,
        ease: 'expo.out',
        delay: 0.3,
      });

      gsap.from('.footer-line', {
        yPercent: 120,
        opacity: 0,
        duration: 0.6,
        ease: 'expo.out',
        stagger: -0.12,
        delay: 0.6,
      });

      gsap.from('.latest', {
        yPercent: 120,
        opacity: 0,
        duration: 1.1,
        ease: 'expo.out',
        delay: 1.6,
      });

      gsap.from('.line-works', {
        scaleX: 0,
        transformOrigin: 'left center',
        opacity: 1,
        duration: 1.1,
        ease: 'expo.out',
        delay: 0.4,
        stagger: 0.1
      })

      gsap.from('.project-card', {
        yPercent: 120,
        opacity: 0,
        duration: 1.3,
        ease: 'expo.out',
        stagger: 0.11,
        delay: 0.55
      })

      gsap.from('.project-detail', {
        yPercent: 120,
        opacity: 0,
        duration: 1.3,
        ease: 'expo.out',
        stagger: 0,
        delay: 0.2
      })

      gsap.from('.work-split', {
        duration: 0.9,
        y: 8,
        opacity: 0,
        scale: 0.6,
        stagger: 0.08,
        ease: 'expo.out',
        delay: 0.65,
      });

      gsap.fromTo(
        '.project-slide',
        { xPercent: -40, autoAlpha: 0 },
        {
          xPercent: 0,
          autoAlpha: 1,
          duration: 0.9,
          stagger: 0.03,
          ease: 'expo.out',
          delay: 0.65,
          immediateRender: false,
          clearProps: 'transform,willChange',
        }
      );

      gsap.from('.on-this-page', {
        yPercent: 120,
        opacity: 0,
        duration: 1.1,
        ease: 'expo.out',
        delay: 0.5,
      });
    };

    const scheduleAnimations = () => {
      if ('requestIdleCallback' in window) {
        requestIdleCallback(() => runAnimations(), { timeout: 2000 });
      } else {
        setTimeout(() => runAnimations(), 500);
      }
    };

    if (document.readyState === 'complete') {
      scheduleAnimations();
    } else {
      window.addEventListener('load', scheduleAnimations, { once: true });
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initAnimations, { once: true });
  } else {
    initAnimations();
  }
</script>
