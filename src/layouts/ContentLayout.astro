---
const { class: className } = Astro.props;
---

<div class={`content-layout ${className ?? ''}`.trim()}>
    <slot />
</div>

<style>
    .content-layout {
        position: relative;
        z-index: 1;
        width: min(100%, 750px);
        margin: 0 auto;
        min-height: 100vh;
        padding: 2rem;
        box-sizing: border-box;
        border-width: 1px;
        border-color: color-mix(in oklab, var(--color-ink) /* #1a1a1a */ 20%, transparent);
    }
</style>