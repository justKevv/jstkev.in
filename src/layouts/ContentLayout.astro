---
const { class: className } = Astro.props;
---

<div class={`content-layout${className ?? ''}`}>
    <slot />
</div>

<style>
    .content-layout {
        position: relative;
        z-index: 1;
        width: min(100vw, 700px);
        margin: 0 auto;
        min-height: 100vh;
        padding: 2rem;
        box-sizing: border-box;
    }
</style>